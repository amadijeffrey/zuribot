# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/zuribot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_API_KEY=your_secure_admin_api_key_here

# Subscription Plans (amounts in kobo - e.g., 5000 = ₦50.00)
WEALTH_PLAN_AMOUNT=500000
BOOST_PLAN_AMOUNT=1000000
PREMIUM_PLAN_AMOUNT=2500000

# Grace Period
GRACE_PERIOD_DAYS=3

# Feature Flags (optional logging tables)
ENABLE_WEBHOOK_LOGGING=true
ENABLE_MESSAGE_LOGGING=true