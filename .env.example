# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Domain Caddy will serve (used by docker-compose). Leave blank for local dev.
DOMAIN=yourdomain.com

# Database
#
# Use ONE of the two URL shapes below depending on whether your Postgres is
# behind a transaction-mode connection pooler (pgbouncer / Supabase Pooler /
# Neon pooler / RDS Proxy) or directly reachable.
#
# (A) DIRECT Postgres (RDS, Railway, Render, Neon direct, self-hosted):
#     DATABASE_URL="postgresql://user:pass@host:5432/db?connection_limit=15&pool_timeout=20&sslmode=require"
#     Leave DIRECT_URL empty — Prisma uses DATABASE_URL for migrations too.
#
# (B) Behind a transaction-mode pooler (Supabase Pooler, Neon pooler, RDS Proxy):
#     DATABASE_URL="postgresql://user:pass@pooler-host:6543/db?pgbouncer=true&connection_limit=15&pool_timeout=20"
#     DIRECT_URL="postgresql://user:pass@direct-host:5432/db"
#     pgbouncer=true is REQUIRED — Prisma disables prepared statements that
#     don't survive transaction-mode pooling.
#
# connection_limit=15 + pool_timeout=20 are sensible defaults for this app's
# worker concurrency (3 messages + 2 notifications + webhook handlers + crons).
DATABASE_URL="postgresql://postgres:password@localhost:5432/zuribot?schema=public&connection_limit=15&pool_timeout=20"
DIRECT_URL=""

# Redis
REDIS_URL="redis://localhost:6379"

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_HEALTH_PLAN_CODE=plan-code
PAYSTACK_WEALTH_PLAN_CODE=plan-code
PAYSTACK_BOOST_PLAN_CODE=plan-code

# Admin
ADMIN_API_KEY=your_secure_admin_api_key_here

# Subscription Plans (amounts in kobo - e.g., 5000 = ₦50.00)
WEALTH_PLAN_AMOUNT=500000
BOOST_PLAN_AMOUNT=1000000
PREMIUM_PLAN_AMOUNT=2500000

# Grace Period
GRACE_PERIOD_DAYS=3

# Feature Flags (optional logging tables)
ENABLE_WEBHOOK_LOGGING=false
ENABLE_MESSAGE_LOGGING=false
ALLOWED_ORIGINS=